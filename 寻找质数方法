二，随机算法
方法1：费马素性检验 (Fermat Primality Test)

import random
def fermat_test(n, k=5):
    if n < 2: return False
    if n == 2: return True
    if n % 2 == 0: return False
    for _ in range(k):
        a = random.randint(2, n - 2)
        if pow(a, n - 1, n) != 1:
            return False
    return True

# 测试
print(fermat_test(17))   # True
print(fermat_test(561))  # True (卡迈克尔数，伪质数)

方法2：米勒-拉宾检验 (Miller-Rabin) —— 重点中的重点

import random
def miller_rabin(n, k=12):
    if n < 2: return False
    if n == 2 or n == 3: return True
    if n % 2 == 0: return False

    # 写出 n-1 = d * 2^s
    d = n - 1
    s = 0
    while d % 2 == 0:
        d //= 2
        s += 1

    for _ in range(k):
        a = random.randint(2, n - 2)
        x = pow(a, d, n)
        if x == 1 or x == n - 1:
            continue
        for _ in range(s - 1):
            x = (x * x) % n
            if x == n - 1:
                break
        else:
            return False
    return True

# 测试
print(miller_rabin(101))   # True
print(miller_rabin(561))   # False (卡迈克尔数被正确识别)






